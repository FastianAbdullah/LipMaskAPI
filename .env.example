# ── App ──
APP_NAME=lip-seg-api
APP_ENV=production
LOG_LEVEL=INFO

# ── Auth ──
# Comma-separated list of API keys.
# Generate one with:  openssl rand -hex 32
API_KEYS=replace_me_with_a_long_random_string

# ── Model ──
MODEL_PATH=models/mobile_deeplabv3_lip.pth
FACE_LANDMARKER_PATH=models/face_landmarker.task
DEVICE=cpu
TORCH_NUM_THREADS=2

# ── Limits ──
MAX_IMAGE_BYTES=10485760
MAX_IMAGE_DIM=4096
INFERENCE_TIMEOUT_SEC=30

# ── Server (gunicorn binds here; nginx proxies to it) ──
HOST=127.0.0.1
PORT=8003
WEB_CONCURRENCY=2

LIP_SEG_API_URL=http://127.0.0.1:8003
LIP_SEG_API_KEY=replace_me_with_a_long_random_string